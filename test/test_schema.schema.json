{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TestRoot",
  "type": "object",
  "properties": {
    "name": { "type": "string", "minLength": 2 },
    "age": { "type": "integer", "minimum": 0, "multipleOf": 5 },
    "height": { "type": "number" },
    "email": { "type": "string", "pattern": "^[a-zA-Z0-9.]+@[a-zA-Z0-9.]+$" },
    "uuid": { "type": "string", "format": "uuid" },
    "isAwesome": { "type": "boolean" },
    "class": { "type": "string" },
    "reader": { "type": "string" },
    "stack": { "type": "string" },
    "validate": { "type": "string" },
    "result": { "type": "string" },
    "address": { "$ref": "#/$defs/Address" },
    "tags": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string" }
    },
    "scores": {
      "type": "array",
      "items": { "$ref": "#/$defs/Score" }
    },
    "unionValue": {
      "oneOf": [
        { "type": "string" },
        { "$ref": "#/$defs/Address" }
      ]
    },
    "nullableString": {
      "type": ["string", "null"]
    },
    "pet": { "$ref": "#/$defs/Pet" }
  },
  "required": ["name", "age", "isAwesome", "address"],
  "$defs": {
    "Address": {
      "title": "Address",
      "type": "object",
      "properties": {
        "city": { "type": "string", "minLength": 3 },
        "street": { "type": "string" }
      },
      "required": ["city"]
    },
    "Score": {
      "title": "Score",
      "type": "object",
      "properties": {
        "value": { "type": "number", "minimum": 0.0 }
      },
      "required": ["value"]
    },
    "Cat": {
      "title": "Cat",
      "type": "object",
      "properties": {
        "kind": { "type": "string" },
        "meowVolume": { "type": "number" }
      },
      "required": ["kind"]
    },
    "Dog": {
      "title": "Dog",
      "type": "object",
      "properties": {
        "kind": { "type": "string" },
        "barkVolume": { "type": "number" }
      },
      "required": ["kind"]
    },
    "Pet": {
      "title": "Pet",
      "oneOf": [
        { "$ref": "#/$defs/Cat" },
        { "$ref": "#/$defs/Dog" }
      ],
      "discriminator": {
        "propertyName": "kind",
        "mapping": {
          "cat_type": "#/$defs/Cat",
          "dog_type": "#/$defs/Dog"
        }
      }
    }
  }
}
