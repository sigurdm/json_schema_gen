{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TestRoot",
  "type": "object",
  "definitions": {
    "Dummy": { "type": "string" }
  },
  "properties": {
    "name": { "type": "string", "minLength": 2 },
    "constValue": { "const": "always-this-value" },
    "age": { "type": "integer", "minimum": 0, "multipleOf": 5 },
    "exclusiveAge": { "type": "integer", "exclusiveMinimum": 0, "exclusiveMaximum": 100 },
    "height": { "type": "number" },
    "email": { "type": "string", "pattern": "^[a-zA-Z0-9.]+@[a-zA-Z0-9.]+$" },
    "uuid": { "type": "string", "format": "uuid" },
    "isAwesome": { "type": "boolean" },
    "class": { "type": "string" },
    "reader": { "type": "string" },
    "stack": { "type": "string" },
    "validate": { "type": "string" },
    "result": { "type": "string" },
    "address": { "$ref": "#/$defs/Address" },
    "tags": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string" }
    },
    "scores": {
      "type": "array",
      "items": { "$ref": "#/$defs/Score" }
    },
    "unionValue": {
      "oneOf": [
        { "type": "string" },
        { "$ref": "#/$defs/Address" }
      ]
    },
    "nullableString": {
      "type": ["string", "null"]
    },
    "pet": { "$ref": "#/$defs/Pet" },
    "restrictedObject": { "$ref": "#/$defs/RestrictedObject" },
    "dependentObject": { "$ref": "#/$defs/DependentObject" },
    "restrictedArray": {
      "type": "array",
      "items": { "type": "integer" },
      "contains": { "type": "integer", "minimum": 5, "multipleOf": 3 },
      "minContains": 1,
      "maxContains": 2
    },
    "deprecatedField": {
      "type": "string",
      "deprecated": true
    },
    "deprecatedRef": {
      "$ref": "#/$defs/DeprecatedObject"
    },
    "defaultString": {
      "type": "string",
      "default": "default value"
    },
    "defaultInt": {
      "type": "integer",
      "default": 42
    },
    "defaultBool": {
      "type": "boolean",
      "default": true
    },
    "defaultList": {
      "type": "array",
      "items": { "type": "string" },
      "default": ["a", "b"]
    },
    "defaultObject": {
      "$ref": "#/$defs/Address",
      "default": { "city": "Default City" }
    },
    "defaultNullableString": {
      "type": ["string", "null"],
      "default": null
    },
    "mergedValue": {
      "$ref": "#/$defs/Merged"
    },
    "tupleArray": {
      "type": "array",
      "prefixItems": [
        { "type": "string" },
        { "type": "integer" }
      ],
      "items": { "type": "boolean" }
    },
    "tupleObjectArray": {
      "type": "array",
      "prefixItems": [
        { "$ref": "#/$defs/Address" },
        { "$ref": "#/$defs/Cat" }
      ]
    },
    "ipv6Value": {
      "type": "string",
      "format": "ipv6"
    },
    "hostnameValue": {
      "type": "string",
      "format": "hostname"
    },
    "timeValue": {
      "type": "string",
      "format": "time"
    },
    "uriReferenceValue": {
      "type": "string",
      "format": "uri-reference"
    },
    "additionalPropertiesObject": {
      "$ref": "#/$defs/MapObject"
    },
    "strictObject": {
      "$ref": "#/$defs/StrictObject"
    },
    "notObject": {
      "$ref": "#/$defs/NotObject"
    },
    "anyOfValue": {
      "anyOf": [
        { "type": "string" },
        { "type": "integer" }
      ]
    },
    "mergedAllOfObject": {
      "$ref": "#/$defs/MergedAllOfObject"
    },
    "complexMerged": { "$ref": "#/$defs/ComplexMergedObject" },
    "myEnumField": { "$ref": "#/$defs/MyEnum" },
    "unionContainsArray": {
      "type": "array",
      "contains": {
        "oneOf": [
          { "type": "string", "minLength": 3, "maxLength": 10, "pattern": "^a", "format": "email" },
          { "type": "integer", "minimum": 5, "maximum": 10, "multipleOf": 2 },
          { "type": "number", "exclusiveMinimum": 5.0, "exclusiveMaximum": 11.0, "multipleOf": 0.5 }
        ]
      }
    },
    "objectContainsArray": {
      "type": "array",
      "contains": { "$ref": "#/$defs/Address" }
    },
    "enumContainsArray": {
      "type": "array",
      "contains": { "$ref": "#/$defs/MyEnum" }
    },
    "booleanContainsArray": {
      "type": "array",
      "contains": { "type": "boolean" }
    },
    "nullContainsArray": {
      "type": "array",
      "contains": { "type": "null" }
    },
    "anyContainsArray": {
      "type": "array",
      "contains": {}
    },
    "stringContainsArray": {
      "type": "array",
      "contains": { "type": "string", "minLength": 3, "maxLength": 10, "pattern": "^a", "format": "email" }
    },
    "numberContainsArray": {
      "type": "array",
      "contains": {
        "type": "number",
        "minimum": 5.0,
        "maximum": 10.0,
        "exclusiveMinimum": 4.5,
        "exclusiveMaximum": 10.5,
        "multipleOf": 0.5
      }
    },
    "dynamicProps": {
      "$ref": "#/$defs/ObjectWithDynamicProps"
    },
    "dateTimeField": {
      "type": "string",
      "format": "date-time"
    },
    "dateField": {
      "type": "string",
      "format": "date"
    },
    "ipv4Field": {
      "type": "string",
      "format": "ipv4"
    },
    "uriField": {
      "type": "string",
      "format": "uri"
    },
    "defaultEmptyList": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },
    "defaultEmptyObject": {
      "$ref": "#/$defs/MapObject",
      "default": {}
    },
    "unionWithArrayOption": {
      "oneOf": [
        { "type": "string" },
        {
          "type": "array",
          "items": { "$ref": "#/$defs/Address" }
        }
      ]
    },
    "impossibleField": {
      "allOf": [
        { "type": "string" },
        { "type": "integer" }
      ]
    },
    "tupleSameTypeArray": {
      "type": "array",
      "prefixItems": [
        { "type": "string", "minLength": 1 },
        { "type": "string", "maxLength": 5 }
      ],
      "items": { "type": "string" }
    },
    "arrayWithAllOfItems": {
      "type": "array",
      "items": {
        "allOf": [
          { "type": "object", "properties": { "a": { "type": "string" } } },
          { "type": "object", "properties": { "b": { "type": "integer" } } }
        ]
      }
    },
    "unionWithAllOfOption": {
      "oneOf": [
        { "type": "string" },
        {
          "allOf": [
            { "type": "object", "properties": { "a": { "type": "string" } } },
            { "type": "object", "properties": { "b": { "type": "integer" } } }
          ]
        }
      ]
    },
    "deprecatedFieldWithMessage": {
      "type": "string",
      "x-deprecated-message": "Use newAwesomeField instead"
    },
    "customNamedObject": {
      "type": "object",
      "x-dart-name": "MyCustomClassName",
      "properties": {
        "foo": { "type": "string" }
      }
    },
    "customNamedUnion": {
      "x-dart-name": "MyCustomUnionName",
      "x-deprecated-message": "This union is deprecated, use MyCustomUnionName2",
      "oneOf": [
        { "type": "string" },
        { "type": "integer" }
      ]
    },
    "customNamedEnum": {
      "x-dart-name": "MyCustomEnumName",
      "type": "string",
      "enum": ["one", "two"]
    },
    "coverageTrigger": {
      "type": "object",
      "properties": {
        "mergeArray": {
          "allOf": [
            { "type": "array", "items": { "type": "string" } },
            {}
          ]
        },
        "mergeString": {
          "allOf": [
            { "type": "string", "minLength": 2 },
            { "type": "string", "maxLength": 10 }
          ]
        },
        "mergeNumber": {
          "allOf": [
            { "type": "number", "minimum": 1 },
            { "type": "number", "maximum": 10 }
          ]
        },
        "mergeBoolean": {
          "allOf": [
            { "type": "boolean" },
            {}
          ]
        },
        "mergeNull": {
          "allOf": [
            { "type": "null" },
            {}
          ]
        },
        "mergeAnything": {
          "allOf": [
            {},
            {}
          ]
        },
        "mergeNever": {
          "allOf": [
            { "not": {} },
            { "type": "string" }
          ]
        },
        "mergeRef": {
          "allOf": [
            {},
            { "$ref": "#/$defs/MapObject" }
          ]
        },
        "mergeEnum": {
          "allOf": [
            { "type": "string", "enum": ["a", "b"] },
            {}
          ]
        },
        "mergeUnion": {
          "allOf": [
            { "oneOf": [ { "type": "string" }, { "type": "integer" } ] },
            {}
          ]
        },
        "mergeObjectsWithNoAdditional": {
          "allOf": [
            { "type": "object", "additionalProperties": false },
            { "type": "object", "additionalProperties": false }
          ]
        }
      }
    }
  },
  "required": ["name", "age", "isAwesome", "address"],
  "$defs": {
    "ObjectWithDynamicProps": {
      "title": "ObjectWithDynamicProps",
      "type": "object",
      "properties": {
        "notInt": {
          "not": { "type": "integer" }
        },
        "notNum": {
          "not": { "type": "number" }
        }
      }
    },
    "MapObject": {
      "title": "MapObject",
      "type": "object",
      "properties": {
        "name": { "type": "string" }
      },
      "additionalProperties": { "type": "string" }
    },
    "StrictObject": {
      "title": "StrictObject",
      "type": "object",
      "properties": {
        "name": { "type": "string" }
      },
      "additionalProperties": false
    },
    "NotObject": {
      "title": "NotObject",
      "type": "object",
      "properties": {
        "notPatternString": {
          "type": "string",
          "not": { "pattern": "forbidden" }
        },
        "notEnumInt": {
          "type": "integer",
          "not": { "enum": [13, 17] }
        },
        "notNullValue": {
          "not": { "type": "null" }
        }
      },
      "required": ["notPatternString", "notEnumInt", "notNullValue"]
    },
    "MergedAllOfObject": {
      "title": "MergedAllOfObject",
      "type": "object",
      "allOf": [
        {
          "properties": {
            "strVal": {
              "type": "string",
              "minLength": 3,
              "maxLength": 10,
              "pattern": "^a"
            },
            "numVal": {
              "type": "number",
              "minimum": 0,
              "maximum": 100,
              "multipleOf": 5
            }
          },
          "dependentRequired": {
            "strVal": ["numVal"]
          }
        },
        {
          "properties": {
            "strVal": {
              "type": "string",
              "minLength": 5,
              "maxLength": 8,
              "format": "email"
            },
            "numVal": {
              "type": "number",
              "minimum": 10,
              "maximum": 50
            }
          }
        }
      ]
    },
    "MyEnum": {
      "title": "MyEnum",
      "type": "string",
      "enum": ["alpha", "beta", "gamma"]
    },
    "ComplexMergedObject": {
      "title": "ComplexMergedObject",
      "type": "object",
      "allOf": [
        {
          "properties": {
            "numVal": {
              "type": "number",
              "exclusiveMinimum": 5.0,
              "exclusiveMaximum": 25.0
            }
          },
          "additionalProperties": {
            "type": "string"
          },
          "minProperties": 1,
          "maxProperties": 10
        },
        {
          "properties": {
            "numVal": {
              "type": "number",
              "exclusiveMinimum": 10.0,
              "exclusiveMaximum": 20.0
            }
          },
          "additionalProperties": {
            "type": "string",
            "minLength": 3
          },
          "minProperties": 2,
          "maxProperties": 5
        }
      ]
    },
    "Address": {
      "title": "Address",
      "type": "object",
      "properties": {
        "city": { "type": "string", "minLength": 3 },
        "street": { "type": "string" }
      },
      "required": ["city"]
    },
    "Score": {
      "title": "Score",
      "type": "object",
      "properties": {
        "value": { "type": "number", "minimum": 0.0 }
      },
      "required": ["value"]
    },
    "Cat": {
      "title": "Cat",
      "type": "object",
      "properties": {
        "kind": { "type": "string" },
        "meowVolume": { "type": "number" }
      },
      "required": ["kind"]
    },
    "Dog": {
      "title": "Dog",
      "type": "object",
      "properties": {
        "kind": { "type": "string" },
        "barkVolume": { "type": "number" }
      },
      "required": ["kind"]
    },
    "Pet": {
      "title": "Pet",
      "oneOf": [
        { "$ref": "#/$defs/Cat" },
        { "$ref": "#/$defs/Dog" }
      ],
      "discriminator": {
        "propertyName": "kind",
        "mapping": {
          "cat_type": "#/$defs/Cat",
          "dog_type": "#/$defs/Dog"
        }
      }
    },
    "RestrictedObject": {
      "title": "RestrictedObject",
      "type": "object",
      "properties": {
        "a": { "type": "string" },
        "b": { "type": "string" },
        "c": { "type": "string" }
      },
      "minProperties": 1,
      "maxProperties": 2
    },
    "DependentObject": {
      "title": "DependentObject",
      "type": "object",
      "properties": {
        "creditCard": { "type": "number" },
        "billingAddress": { "type": "string" }
      },
      "dependentRequired": {
        "creditCard": ["billingAddress"]
      }
    },
    "DeprecatedObject": {
      "title": "DeprecatedObject",
      "type": "object",
      "deprecated": true,
      "properties": {
        "value": { "type": "string" }
      }
    },
    "A": {
      "title": "A",
      "type": "object",
      "properties": {
        "a": { "type": "string" }
      }
    },
    "B": {
      "title": "B",
      "type": "object",
      "properties": {
        "b": { "type": "integer" }
      }
    },
    "Merged": {
      "title": "Merged",
      "allOf": [
        { "$ref": "#/$defs/A" },
        { "$ref": "#/$defs/B" }
      ],
      "properties": {
        "c": { "type": "boolean" }
      }
    }
  }
}
